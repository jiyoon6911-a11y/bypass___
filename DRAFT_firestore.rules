rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'username', 'displayName', 'historyPrivacy', 'onboardingCompleted', 'createdAt', 'updatedAt'])
        && data.uid is string && data.uid.size() >= 1 && data.uid.size() <= 128
        && data.username is string && data.username.size() <= 128
        && data.displayName is string && data.displayName.size() <= 128
        && data.historyPrivacy is string && data.historyPrivacy.size() <= 20
        && data.onboardingCompleted is bool
        && (
            !('preferences' in data.keys()) || (
                data.preferences is map 
                // We're lax on sub-fields as long as it's a map to avoid breaking
            )
        )
        && (!('photoURL' in data.keys()) || (data.photoURL is string && data.photoURL.size() <= 2048))
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }
    
    function isValidReview(data) {
      return data.keys().hasAll(['authorId', 'showName', 'rating', 'content', 'createdAt'])
        && data.authorId is string && data.authorId.size() <= 128
        && data.showName is string && data.showName.size() <= 256
        && data.rating is number
        && data.content is string && data.content.size() <= 10000
        && (!('authorName' in data.keys()) || (data.authorName is string && data.authorName.size() <= 128))
        && (!('authorPhoto' in data.keys()) || (data.authorPhoto is string && data.authorPhoto.size() <= 2048))
        && (!('ticketDetails' in data.keys()) || (data.ticketDetails is string && data.ticketDetails.size() <= 1024))
        && data.createdAt is timestamp;
    }
    
    function isValidFollow(data) {
       return data.keys().hasAll(['followerId', 'followingId', 'createdAt'])
        && data.followerId is string && data.followerId.size() <= 128
        && data.followingId is string && data.followingId.size() <= 128
        && data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn() && resource.data.username is string;
      
      allow create: if isSignedIn() 
        && isValidId(userId) 
        && userId == request.auth.uid
        && incoming().uid == request.auth.uid
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time
        && isValidUser(incoming())
        && incoming().keys().size() <= 9;
        
      allow update: if isSignedIn() 
        && isValidId(userId)
        && userId == request.auth.uid
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && isValidUser(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly([
            'username', 'displayName', 'photoURL', 'historyPrivacy', 'onboardingCompleted', 'preferences', 'updatedAt'
        ]);
        
      allow delete: if isSignedIn() && isValidId(userId) && userId == request.auth.uid;
    }

    match /reviews/{reviewId} {
      allow get: if isSignedIn() && isValidId(reviewId);
      allow list: if isSignedIn() && resource.data.authorId is string;
      
      allow create: if isSignedIn()
        && isValidId(reviewId)
        && incoming().authorId == request.auth.uid
        && isValidReview(incoming());
        
      allow update: if isSignedIn()
        && isValidId(reviewId)
        && existing().authorId == request.auth.uid
        && incoming().authorId == request.auth.uid
        && incoming().createdAt == existing().createdAt
        && isValidReview(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'content', 'ticketDetails']);
        
      allow delete: if isSignedIn() && isValidId(reviewId) && existing().authorId == request.auth.uid;
    }

    match /follows/{followId} {
      allow get: if isSignedIn() && isValidId(followId);
      allow list: if isSignedIn() && (resource.data.followerId == request.auth.uid || resource.data.followingId == request.auth.uid || resource.data.followerId is string);
      
      allow create: if isSignedIn()
        && isValidId(followId)
        && incoming().followerId == request.auth.uid
        && isValidFollow(incoming());
        
      allow delete: if isSignedIn() && isValidId(followId) && existing().followerId == request.auth.uid;
    }
  }
}
