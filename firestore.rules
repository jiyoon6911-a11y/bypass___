rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ---- Global Safety Net ----
    match /{document=**} {
      allow read, write: if false;
    }

    // ---- Reusable Helpers ----
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    // ---- Entities Validation ----
    
    // User validation
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName', 'historyPrivacy', 'createdAt', 'updatedAt', 'onboardingCompleted'])
        && data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid
        && data.displayName is string && data.displayName.size() <= 100
        && data.historyPrivacy is string && data.historyPrivacy in ['public', 'followers', 'private']
        && data.createdAt is timestamp
        && data.updatedAt is timestamp
        && data.onboardingCompleted is bool
        && (data.keys().hasAll(['photoURL']) ? (data.photoURL is string && data.photoURL.size() <= 1000) : true)
        && (data.keys().hasAll(['preferences']) ? (data.preferences is map) : true);
    }
    
    function isFollower(targetId, myId) {
      // is myId following targetId?
      let followId = myId + '_' + targetId;
      return exists(/databases/$(database)/documents/follows/$(followId));
    }
    
    match /users/{userId} {
      allow get: if isSignedIn(); // can view profiles
      // allow listing users by username for the search function
      allow list: if isSignedIn() && resource.data.username != null; 
      
      allow create: if isSignedIn() 
        && isValidId(userId) 
        && userId == request.auth.uid 
        && isValidUser(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isSignedIn()
        && userId == request.auth.uid
        && incoming().createdAt == existing().createdAt
        && incoming().uid == existing().uid
        && incoming().updatedAt == request.time;
    }

    // Review validation
    function isValidReview(data) {
      return data.keys().hasAll(['authorId', 'showName', 'rating', 'content', 'createdAt'])
        && data.authorId is string && data.authorId == request.auth.uid
        && data.showName is string && data.showName.size() <= 200
        && data.rating is number && data.rating >= 0 && data.rating <= 5
        && data.content is string && data.content.size() <= 10000
        && data.createdAt is timestamp
        && (data.keys().hasAll(['authorName']) ? (data.authorName is string && data.authorName.size() <= 100) : true)
        && (data.keys().hasAll(['authorPhoto']) ? (data.authorPhoto is string && data.authorPhoto.size() <= 1000) : true)
        && (data.keys().hasAll(['ticketDetails']) ? (data.ticketDetails is string && data.ticketDetails.size() <= 1000) : true);
    }
    
    match /reviews/{reviewId} {
      allow get: if isSignedIn();
      
      allow list: if isSignedIn() && (resource.data.showName != null || resource.data.authorId == request.auth.uid || resource.data.authorId != null);
      
      allow create: if isSignedIn()
        && isValidId(reviewId)
        && isValidReview(incoming())
        && incoming().createdAt == request.time
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
        
      allow update: if isSignedIn()
        && existing().authorId == request.auth.uid
        && isValidReview(incoming())
        && incoming().authorId == existing().authorId
        && incoming().createdAt == existing().createdAt;
        
      allow delete: if isSignedIn() && existing().authorId == request.auth.uid;
    }
    
    // Follow validation
    function isValidFollow(data) {
      return data.keys().hasAll(['followerId', 'followingId', 'createdAt'])
        && data.keys().size() == 3
        && data.followerId is string && data.followerId == request.auth.uid
        && data.followingId is string && isValidId(data.followingId)
        && data.createdAt is timestamp;
    }
    
    match /follows/{followId} {
      allow get: if isSignedIn() && (existing().followerId == request.auth.uid || existing().followingId == request.auth.uid);
      allow list: if isSignedIn() && (resource.data.followerId == request.auth.uid || resource.data.followingId == request.auth.uid);
      
      allow create: if isSignedIn()
        && followId == request.auth.uid + '_' + incoming().followingId
        && isValidFollow(incoming())
        && incoming().createdAt == request.time
        && exists(/databases/$(database)/documents/users/$(incoming().followingId));
        
      allow delete: if isSignedIn() && existing().followerId == request.auth.uid;
    }
  }
}
