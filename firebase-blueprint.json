{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with privacy settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "historyPrivacy": { "type": "string", "enum": ["public", "followers", "private"] },
        "onboardingCompleted": { "type": "boolean" },
        "preferences": {
           "type": "object",
           "properties": {
             "genres": { "type": "array" },
             "accessibility": { "type": "array" },
             "services": { "type": "array" }
           }
        },
        "createdAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["uid", "username", "displayName", "historyPrivacy", "onboardingCompleted", "createdAt", "updatedAt"]
    },
    "Review": {
      "title": "Review",
      "description": "User's review & concert history ticket",
      "type": "object",
      "properties": {
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "showName": { "type": "string" },
        "ticketDetails": { "type": "string" },
        "rating": { "type": "number" },
        "content": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["authorId", "showName", "rating", "content", "createdAt"]
    },
    "Follow": {
      "title": "Follow",
      "description": "Follower relationship",
      "type": "object",
      "properties": {
        "followerId": { "type": "string" },
        "followingId": { "type": "string" },
        "createdAt": { "type": "number" }
      },
      "required": ["followerId", "followingId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Public user profiles"
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Reviews left by users"
    },
    "/follows/{followId}": {
      "schema": { "$ref": "#/entities/Follow" },
      "description": "Graph edges for follows"
    }
  }
}
